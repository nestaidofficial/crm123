NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (https://supabase.com → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER-SIDE ONLY, never prefix with NEXT_PUBLIC_
# Used for: Storage uploads to private buckets, agency signup confirmation
# Get from: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Retell AI (for AI Receptionist voice calls)
# Get from: https://www.retellai.com → Dashboard → API Keys
RETELL_API_KEY=

# Google Maps (for EVV GPS location verification and distance calculations)
# Enable: Maps JavaScript API and Geocoding API at https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google Maps Server Key (for server-side geocoding in auto-scheduler)
# SERVER-SIDE ONLY, never prefix with NEXT_PUBLIC_
# Falls back to NEXT_PUBLIC_GOOGLE_MAPS_API_KEY if not set
GOOGLE_MAPS_SERVER_KEY=your-server-side-google-maps-api-key

# ─── Multi-tenancy notes ────────────────────────────────────────────
# After running migrations 023–030 and setting up your first agency:
#
# 1. Run: supabase db push (or apply migrations manually via Dashboard SQL editor)
# 2. Sign up at /signup to create your first agency workspace
# 3. The signup flow automatically creates:
#    - agencies row
#    - agency_members row (role = owner)
#    - employees row (linked to auth.uid())
# ───────────────────────────────────────────────────────────────────
